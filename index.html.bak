        <rect x="3" y="14" width="7" height="7" rx="1"/>
        <line x1="14" y1="14" x2="14" y2="20"/><line x1="14" y1="14" x2="20" y2="14"/><line x1="20" y1="17" x2="20" y2="20"/><line x1="17" y1="20" x2="20" y2="20"/>
