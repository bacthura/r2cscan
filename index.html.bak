</div>

<!-- MODAL ADMIN LOGIN -->
<div class="modal-overlay" id="modal-admin-login">
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <h2 style="font-family:var(--font-head);font-size:1.2rem;margin-bottom:6px">Acesso Admin</h2>
    <p style="font-size:.8rem;color:var(--text2);margin-bottom:16px">Digite a senha para acessar o painel administrativo</p>
