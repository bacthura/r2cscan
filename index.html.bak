  <div id="ai-status">
    <div class="ai-spinner"></div>
    <p><strong id="ai-status-title">Analisando imagem com IA…</strong><span id="ai-status-desc">Aguarde enquanto identificamos o objeto</span></p>
  </div>

  <div style="margin-top:14px">
    <button class="btn btn-secondary" id="capture-btn" onclick="captureAndAnalyze()" style="display:none">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px"><circle cx="12" cy="12" r="4"/><path d="M8.5 3H3v5.5M20.5 3H15v-0M3 15.5V21h5.5M20.5 21H15v0M15 3h5.5v5.5"/></svg>
