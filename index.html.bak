    </div>
    <button class="btn btn-primary" onclick="checkAdminPw()">Entrar</button>
    <button class="btn btn-secondary" style="margin-top:10px" onclick="closeAdminModal()">Cancelar</button>
    <p style="font-size:.7rem;color:var(--text2);text-align:center;margin-top:12px">Senha padrão: <strong style="color:var(--accent)">admin123</strong></p>
  </div>
</div>

<!-- TOAST -->
<div id="toast"></div>

<script>
// ════════════════════════════════════
//  DATABASE (IndexedDB)
// ════════════════════════════════════
let db;
const DB_NAME = 'R2C-Scan', DB_VER = 1, STORE = 'products';

function initDB() {
  return new Promise((res, rej) => {
    const req = indexedDB.open(DB_NAME, DB_VER);
    req.onupgradeneeded = e => {
      const d = e.target.result;
      if (!d.objectStoreNames.contains(STORE)) {
        const s = d.createObjectStore(STORE, { keyPath: 'id' });
        s.createIndex('sku', 'sku', { unique: false });
        s.createIndex('category', 'category', { unique: false });
      }
    };
    req.onsuccess = e => { db = e.target.result; res(); };
    req.onerror = rej;
  });
}

async function dbGetAll() {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readonly');
    const req = tx.objectStore(STORE).getAll();
    req.onsuccess = () => res(req.result);
    req.onerror = rej;
  });
}

async function dbPut(item) {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readwrite');
    const req = tx.objectStore(STORE).put(item);
    req.onsuccess = () => res();
    req.onerror = rej;
  });
}

async function dbDelete(id) {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readwrite');
    const req = tx.objectStore(STORE).delete(id);
    req.onsuccess = () => res();
    req.onerror = rej;
  });
}

async function dbGetById(id) {
  return new Promise((res, rej) => {
    const tx = db.transaction(STORE, 'readonly');
    const req = tx.objectStore(STORE).get(id);
    req.onsuccess = () => res(req.result);
    req.onerror = rej;
  });
}

// ════════════════════════════════════
//  STATE
// ════════════════════════════════════
let currentPage = 'page-home';
let scanMode = 'qr';
let videoStream = null;
let scanInterval = null;
let currentFilter = 'todos';
let isAdmin = false;
let editingId = null;
let currentDetailId = null;
let photoDataURL = null;
const ADMIN_PW = 'admin123';

// ════════════════════════════════════
//  NAVIGATION
// ════════════════════════════════════
function goPage(pageId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(pageId).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const map = {'page-home':'nav-home','page-scanner':'nav-scanner','page-catalog':'nav-catalog','page-admin':'nav-admin'};
  if(map[pageId]) document.getElementById(map[pageId]).classList.add('active');
  currentPage = pageId;
  if (pageId === 'page-scanner') startCamera();
  else stopCamera();
  if (pageId === 'page-catalog') renderCatalog();
  if (pageId === 'page-home') renderHome();
  if (pageId === 'page-admin') renderAdmin();
}

// ════════════════════════════════════
//  CAMERA & SCANNER
// ════════════════════════════════════
async function startCamera() {
  if (videoStream) return;
  try {
    videoStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: { ideal: 'environment' }, width:{ideal:1280}, height:{ideal:720} }
    });
    const video = document.getElementById('scanner-video');
    video.srcObject = videoStream;
    if (scanMode === 'qr') startQRScan();
  } catch(e) { toast('Câmera não disponível'); }
}

function stopCamera() {
  if (videoStream) { videoStream.getTracks().forEach(t => t.stop()); videoStream = null; }
  if (scanInterval) { clearInterval(scanInterval); scanInterval = null; }
}

function setScanMode(mode) {
  scanMode = mode;
  document.getElementById('mode-qr-btn').classList.toggle('active-mode', mode === 'qr');
  document.getElementById('mode-ai-btn').classList.toggle('active-mode', mode === 'ai');
  document.getElementById('capture-btn').style.display = mode === 'ai' ? 'flex' : 'none';
  document.getElementById('scan-result-box').classList.remove('show');
  document.getElementById('ai-status').classList.remove('show');
  if (scanInterval) { clearInterval(scanInterval); scanInterval = null; }
  if (mode === 'qr' && videoStream) startQRScan();
}

function startQRScan() {
  const video = document.getElementById('scanner-video');
  const canvas = document.getElementById('scanner-canvas');
  const ctx = canvas.getContext('2d');
  if (scanInterval) clearInterval(scanInterval);
  scanInterval = setInterval(() => {
    if (video.readyState !== video.HAVE_ENOUGH_DATA) return;
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    ctx.drawImage(video, 0, 0);
    const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    const code = jsQR(imgData.data, imgData.width, imgData.height, { inversionAttempts: 'dontInvert' });
    if (code) {
      clearInterval(scanInterval);
      scanInterval = null;
      handleQRResult(code.data);
    }
  }, 250);
}

function handleQRResult(data) {
  const box = document.getElementById('scan-result-box');
  document.getElementById('scan-result-val').textContent = data;
  box.classList.add('show');
  navigator.vibrate && navigator.vibrate(80);
  toast('QR Code lido!');
  // try to match product
  openProductByQR(data);
}

async function openProductByQR(code) {
  const all = await dbGetAll();
  const prod = all.find(p => p.qrData === code || p.sku === code || p.id === code);
  if (prod) { openDetail(prod, false); }
}

async function openProductByCode() {
  const val = document.getElementById('scan-result-val').textContent;
  const all = await dbGetAll();
  const prod = all.find(p => p.qrData === val || p.sku === val || p.id === val);
  if (prod) openDetail(prod, false);
  else toast('Produto não encontrado no banco');
}

// ════════════════════════════════════
//  AI IMAGE RECOGNITION
// ════════════════════════════════════
async function captureAndAnalyze() {
  const video = document.getElementById('scanner-video');
  const canvas = document.getElementById('scanner-canvas');
  if (!video.srcObject) { toast('Câmera não ativa'); return; }
  canvas.width = video.videoWidth;
  canvas.height = video.videoHeight;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0);
  const imageBase64 = canvas.toDataURL('image/jpeg', 0.8).split(',')[1];

  const status = document.getElementById('ai-status');
  const statusTitle = document.getElementById('ai-status-title');
  const statusDesc = document.getElementById('ai-status-desc');
  status.classList.add('show');
  statusTitle.textContent = 'Analisando imagem com IA…';
  statusDesc.textContent = 'Identificando o objeto capturado';

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{
          role: 'user',
          content: [
            { type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: imageBase64 } },
            { type: 'text', text: 'Identifique o objeto nesta imagem. Responda APENAS em JSON no formato: {"nome":"nome do objeto","categoria":"categoria genérica","descricao":"descrição curta em português","confianca":"alta|media|baixa","sugestao_sku":"SKU sugerido curto"}. Nenhum texto fora do JSON.' }
          ]
        }]
      })
    });
    const data = await response.json();
    const text = data.content.map(i => i.text || '').join('');
    const clean = text.replace(/```json|```/g,'').trim();
    let parsed;
    try { parsed = JSON.parse(clean); } catch(e) { parsed = null; }

    if (parsed) {
      statusTitle.textContent = '✓ Objeto identificado!';
      statusDesc.textContent = `${parsed.nome} — ${parsed.confianca === 'alta' ? 'Alta confiança' : 'Confiança média'}`;

      // try to find in DB
      const all = await dbGetAll();
      const found = all.find(p =>
        p.name.toLowerCase().includes(parsed.nome.toLowerCase()) ||
        parsed.nome.toLowerCase().includes(p.name.toLowerCase()) ||
        (p.category && p.category.toLowerCase() === parsed.categoria.toLowerCase())
      );
      if (found) {
        setTimeout(() => { openDetail(found, true); }, 800);
      } else {
        statusDesc.textContent += ' — Não encontrado no catálogo';
        if (isAdmin) {
          setTimeout(() => {
            document.getElementById('f-name').value = parsed.nome;
            document.getElementById('f-cat').value = parsed.categoria;
            document.getElementById('f-desc').value = parsed.descricao;
            document.getElementById('f-sku').value = parsed.sugestao_sku || '';
            openAddModal();
          }, 1200);
        }
      }
    } else {
      statusTitle.textContent = 'Não foi possível identificar';
      statusDesc.textContent = 'Tente uma foto mais nítida ou com melhor iluminação';
    }
  } catch(e) {
    status.classList.remove('show');
    toast('Erro na análise por IA');
  }
}

// ════════════════════════════════════
//  CATALOG RENDER
// ════════════════════════════════════
async function renderCatalog() {
  const query = (document.getElementById('search-input')?.value || '').toLowerCase();
  const all = await dbGetAll();
  const filtered = all.filter(p => {
    const matchCat = currentFilter === 'todos' || (p.category || '').toLowerCase() === currentFilter.toLowerCase();
    const matchQ = !query || p.name.toLowerCase().includes(query) || (p.sku||'').toLowerCase().includes(query) || (p.category||'').toLowerCase().includes(query);
    return matchCat && matchQ;
  });

  // Update filter chips
  const cats = [...new Set(all.map(p => p.category).filter(Boolean))];
  const filterRow = document.getElementById('filter-row');
  filterRow.innerHTML = '<div class="filter-chip active" data-cat="todos" onclick="setFilter(this)">Todos</div>';
  cats.forEach(c => {
    const chip = document.createElement('div');
    chip.className = 'filter-chip' + (c === currentFilter ? ' active' : '');
    chip.dataset.cat = c;
    chip.textContent = c;
    chip.onclick = () => setFilter(chip);
    filterRow.appendChild(chip);
  });
  if(currentFilter !== 'todos') {
    filterRow.querySelector(`[data-cat="todos"]`).classList.remove('active');
  }

  const list = document.getElementById('catalog-list');
  if (filtered.length === 0) {
    list.innerHTML = `<div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></svg>
      <p>Nenhum produto encontrado</p>
    </div>`;
    return;
  }
  list.innerHTML = filtered.map(p => productCardHTML(p)).join('');
}

function productCardHTML(p) {
  const imgContent = p.photo
    ? `<img src="${p.photo}" alt="${p.name}">`
    : `<div class="no-img" style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;flex-direction:column;gap:6px"><svg viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.5" style="width:32px;height:32px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg><span>Sem imagem</span></div>`;
  return `<div class="product-card" onclick="openDetailById('${p.id}')">
    <div class="card-img">${imgContent}</div>
    <div class="card-body">
      <div class="card-tag">${p.category || 'Geral'}</div>
      <div class="card-name">${p.name}</div>
      <div class="card-sku">${p.sku || 'SKU não definido'}</div>
      <div class="card-footer">
        <div class="status">Cadastrado</div>
        <div style="font-size:.68rem;color:var(--text2)">${new Date(p.createdAt).toLocaleDateString('pt-BR')}</div>
      </div>
    </div>
  </div>`;
}

function setFilter(el) {
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  currentFilter = el.dataset.cat;
  renderCatalog();
}

// ════════════════════════════════════
//  HOME RENDER
// ════════════════════════════════════
async function renderHome() {
  const all = await dbGetAll();
  document.getElementById('stat-total').textContent = all.length;
  const cats = new Set(all.map(p => p.category).filter(Boolean));
  document.getElementById('stat-cats').textContent = cats.size;
  const week = new Date(); week.setDate(week.getDate() - 7);
  document.getElementById('stat-recent').textContent = all.filter(p => new Date(p.createdAt) > week).length;
  document.getElementById('stat-qr').textContent = all.length; // all have QR
  const recent = [...all].sort((a,b) => b.createdAt - a.createdAt).slice(0,3);
  document.getElementById('home-recent').innerHTML = recent.length
    ? recent.map(p => productCardHTML(p)).join('')
    : `<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg><p>Nenhum produto ainda</p></div>`;
}

// ════════════════════════════════════
//  ADMIN RENDER
// ════════════════════════════════════
async function renderAdmin() {
  if (!isAdmin) {
    document.getElementById('admin-list').innerHTML = `<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg><p>Faça login como administrador</p></div>`;
    return;
  }
  const all = await dbGetAll();
  document.getElementById('admin-list').innerHTML = all.length
    ? all.map(p => `<div class="product-card" style="display:flex;gap:12px;align-items:center;padding:12px" onclick="openDetailById('${p.id}')">
        <div style="width:50px;height:50px;border-radius:10px;overflow:hidden;flex-shrink:0;background:var(--bg3);display:flex;align-items:center;justify-content:center">
          ${p.photo ? `<img src="${p.photo}" style="width:100%;height:100%;object-fit:cover">` : `<svg viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.5" style="width:20px;height:20px"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>`}
        </div>
        <div style="flex:1;min-width:0">
          <div style="font-family:var(--font-head);font-size:.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${p.name}</div>
          <div style="font-size:.72rem;color:var(--text2)">${p.sku || '—'} · ${p.category || 'Geral'}</div>
        </div>
        <button onclick="event.stopPropagation();editProduct('${p.id}')" style="background:none;border:1px solid var(--border);border-radius:8px;padding:6px;cursor:pointer">
          <svg viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2" style="width:15px;height:15px"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
      </div>`).join('')
    : `<div class="empty-state"><p>Nenhum produto cadastrado</p></div>`;
}

// ════════════════════════════════════
//  DETAIL VIEW
// ════════════════════════════════════
async function openDetailById(id) {
  const prod = await dbGetById(id);
  if (prod) openDetail(prod, false);
}

function openDetail(prod, byAI) {
  currentDetailId = prod.id;
  document.getElementById('detail-img').src = prod.photo || '';
  document.getElementById('detail-img').style.display = prod.photo ? 'block' : 'none';
  document.getElementById('detail-category').textContent = prod.category || 'Geral';
  document.getElementById('detail-title').textContent = prod.name;
  document.getElementById('detail-sku').textContent = prod.sku ? `SKU: ${prod.sku}` : '';
  document.getElementById('detail-desc').textContent = prod.description || '';
  document.getElementById('detail-ai-badge').style.display = byAI ? 'inline-flex' : 'none';

  // Specs
  const specsHTML = [];
  if (prod.specs) {
    Object.entries(prod.specs).forEach(([k,v]) => {
      specsHTML.push(`<div class="spec-item"><div class="spec-key">${k}</div><div class="spec-val">${v}</div></div>`);
    });
  }
  document.getElementById('detail-specs').innerHTML = specsHTML.join('');

  // Tech table
  const techRows = prod.techSpecs || [];
  if (techRows.length > 0) {
    document.getElementById('detail-tech-table').innerHTML = techRows.map(r =>
      `<div class="tech-spec-row"><span class="tsk">${r.key}</span><span class="tsv">${r.val}</span></div>`
    ).join('');
    document.getElementById('detail-tech-table').style.display = 'block';
  } else {
    document.getElementById('detail-tech-table').style.display = 'none';
  }

  // QR Code
  const qrWrap = document.getElementById('detail-qr-canvas');
  qrWrap.innerHTML = '';
  const qrData = prod.qrData || prod.id;
  new QRCode(qrWrap, { text: qrData, width: 180, height: 180, colorDark:'#000', colorLight:'#fff', correctLevel: QRCode.CorrectLevel.H });
  document.getElementById('detail-qr-label').textContent = prod.sku || prod.id;

  document.getElementById('detail-page').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeDetail() {
  document.getElementById('detail-page').classList.remove('open');
  document.body.style.overflow = '';
  currentDetailId = null;
  // restart scan if on scanner page
  if (currentPage === 'page-scanner' && scanMode === 'qr') startQRScan();
}

async function deleteCurrentProduct() {
  if (!currentDetailId) return;
  if (!confirm('Excluir este produto?')) return;
  await dbDelete(currentDetailId);
  closeDetail();
  toast('Produto excluído');
  renderHome();
}

function shareProduct() {
  if (navigator.share) {
    navigator.share({ title: 'R2C-Scan', text: 'Dados do produto', url: window.location.href });
  } else {
    toast('Compartilhamento não disponível');
  }
}

// ════════════════════════════════════
//  ADD / EDIT MODAL
// ════════════════════════════════════
function openAddModal() {
  editingId = null;
  photoDataURL = null;
  document.getElementById('modal-title').textContent = 'Novo Produto';
  document.getElementById('f-name').value = '';
  document.getElementById('f-sku').value = '';
  document.getElementById('f-cat').value = '';
  document.getElementById('f-desc').value = '';
  document.getElementById('photo-preview').style.display = 'none';
  document.getElementById('upload-label-inner').style.display = 'flex';
  resetSpecFields();
  document.getElementById('modal-add').classList.add('open');
}

async function editProduct(id) {
  const prod = await dbGetById(id);
  if (!prod) return;
  editingId = id;
  photoDataURL = prod.photo || null;
  document.getElementById('modal-title').textContent = 'Editar Produto';
  document.getElementById('f-name').value = prod.name || '';
  document.getElementById('f-sku').value = prod.sku || '';
  document.getElementById('f-cat').value = prod.category || '';
  document.getElementById('f-desc').value = prod.description || '';
  if (prod.photo) {
    document.getElementById('photo-preview').src = prod.photo;
    document.getElementById('photo-preview').style.display = 'block';
    document.getElementById('upload-label-inner').style.display = 'none';
  }
  resetSpecFields();
  if (prod.techSpecs && prod.techSpecs.length > 0) {
    const container = document.getElementById('specs-fields');
    container.innerHTML = '';
    prod.techSpecs.forEach(({key, val}) => addSpecField(key, val));
  }
  document.getElementById('modal-add').classList.add('open');
}

function closeAddModal() {
  document.getElementById('modal-add').classList.remove('open');
}

function resetSpecFields() {
  document.getElementById('specs-fields').innerHTML = `
    <div class="spec-row" style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px">
      <input class="spec-key-input" type="text" placeholder="Campo (ex: Peso)" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 12px;color:var(--text);font-family:var(--font-mono);font-size:.8rem;outline:none">
      <input class="spec-val-input" type="text" placeholder="Valor (ex: 12g)" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 12px;color:var(--text);font-family:var(--font-mono);font-size:.8rem;outline:none">
    </div>`;
}

function addSpecField(k='', v='') {
  const row = document.createElement('div');
  row.className = 'spec-row';
  row.style.cssText = 'display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px';
  row.innerHTML = `
    <input class="spec-key-input" type="text" value="${k}" placeholder="Campo" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 12px;color:var(--text);font-family:var(--font-mono);font-size:.8rem;outline:none">
    <input class="spec-val-input" type="text" value="${v}" placeholder="Valor" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 12px;color:var(--text);font-family:var(--font-mono);font-size:.8rem;outline:none">`;
  document.getElementById('specs-fields').appendChild(row);
}

function previewPhoto(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      photoDataURL = e.target.result;
      document.getElementById('photo-preview').src = photoDataURL;
      document.getElementById('photo-preview').style.display = 'block';
      document.getElementById('upload-label-inner').style.display = 'none';
    };
    reader.readAsDataURL(input.files[0]);
  }
}

async function saveProduct() {
  const name = document.getElementById('f-name').value.trim();
  if (!name) { toast('Nome obrigatório'); return; }

  const sku = document.getElementById('f-sku').value.trim() || `SKU-${Date.now()}`;
  const category = document.getElementById('f-cat').value.trim();
  const description = document.getElementById('f-desc').value.trim();

  // collect specs
  const techSpecs = [];
  document.querySelectorAll('#specs-fields .spec-row').forEach(row => {
    const k = row.querySelector('.spec-key-input').value.trim();
    const v = row.querySelector('.spec-val-input').value.trim();
    if (k && v) techSpecs.push({ key: k, val: v });
  });

  const id = editingId || `prod_${Date.now()}_${Math.random().toString(36).substr(2,5)}`;
  const qrData = `R2CSCAN:${id}`;

  const prod = {
    id, name, sku, category, description, techSpecs,
    photo: photoDataURL || null,
    qrData,
    createdAt: editingId ? (await dbGetById(id))?.createdAt || Date.now() : Date.now(),
    updatedAt: Date.now()
  };

  const btn = document.getElementById('save-btn');
  btn.textContent = 'Salvando…';
  await dbPut(prod);
  btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><path d="M17 21v-8H7v8M7 3v5h8"/></svg>Salvar e Gerar QR Code`;

  closeAddModal();
  toast('Produto salvo com QR Code!');
  renderHome();
  if (currentPage === 'page-catalog') renderCatalog();
  if (currentPage === 'page-admin') renderAdmin();

  // Show detail
  setTimeout(() => openDetail(prod, false), 400);
}

// ════════════════════════════════════
//  ADMIN AUTH
// ════════════════════════════════════
function checkAdmin() {
  if (isAdmin) return true;
  openAdminModal();
  return false;
}

function openAdminModal() {
  document.getElementById('modal-admin-login').classList.add('open');
  setTimeout(() => document.getElementById('admin-pw-input').focus(), 300);
}

function closeAdminModal() {
  document.getElementById('modal-admin-login').classList.remove('open');
  document.getElementById('admin-pw-input').value = '';
}

function checkAdminPw() {
  const pw = document.getElementById('admin-pw-input').value;
  if (pw === ADMIN_PW) {
    isAdmin = true;
    closeAdminModal();
    toast('✓ Acesso admin liberado');
    if (currentPage === 'page-admin') renderAdmin();
  } else {
    document.getElementById('admin-pw-input').style.borderColor = 'var(--danger)';
    setTimeout(() => document.getElementById('admin-pw-input').style.borderColor = '', 1000);
    toast('Senha incorreta');
  }
}

// ════════════════════════════════════
//  TOAST
// ════════════════════════════════════
let toastTimer;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);
}

// ════════════════════════════════════
//  INIT
// ════════════════════════════════════
async function init() {
  await initDB();

  // Seed demo products if empty
  const all = await dbGetAll();
  if (all.length === 0) {
    const demos = [
      { id:'demo1', name:'Parafuso Sextavado M8', sku:'FIX-0001', category:'Fixadores', description:'Parafuso de aço inox grau 8.8, cabeça sextavada, rosca completa.', techSpecs:[{key:'Material',val:'Aço Inox 304'},{key:'Diâmetro',val:'M8'},{key:'Comprimento',val:'40mm'},{key:'Passo',val:'1,25mm'},{key:'Torque',val:'25 N·m'}], photo:null, qrData:'R2CSCAN:demo1', createdAt:Date.now()-86400000*2, updatedAt:Date.now() },
      { id:'demo2', name:'Válvula de Esfera 1/2"', sku:'HID-0042', category:'Hidráulica', description:'Válvula de esfera em latão, passagem plena, rosca BSP.', techSpecs:[{key:'Material',val:'Latão'},{key:'Bitola',val:'1/2" BSP'},{key:'Pressão máx.',val:'20 bar'},{key:'Temperatura',val:'-20°C a 120°C'},{key:'Rosca',val:'BSP'}], photo:null, qrData:'R2CSCAN:demo2', createdAt:Date.now()-86400000, updatedAt:Date.now() },
      { id:'demo3', name:'Disjuntor DIN 20A', sku:'ELE-0108', category:'Elétrica', description:'Disjuntor monopolar curva C para painel elétrico.', techSpecs:[{key:'Corrente',val:'20A'},{key:'Curva',val:'C'},{key:'Tensão',val:'230/400V'},{key:'Polos',val:'1P'},{key:'Norma',val:'IEC 60898'}], photo:null, qrData:'R2CSCAN:demo3', createdAt:Date.now()-3600000*5, updatedAt:Date.now() }
    ];
    for (const d of demos) await dbPut(d);
  }

  renderHome();
  setTimeout(() => {
    document.getElementById('splash').style.opacity = '0';
    setTimeout(() => document.getElementById('splash').style.display = 'none', 500);
  }, 1800);
}

// Close modals on overlay click
document.getElementById('modal-add').addEventListener('click', e => { if(e.target === e.currentTarget) closeAddModal(); });
document.getElementById('modal-admin-login').addEventListener('click', e => { if(e.target === e.currentTarget) closeAdminModal(); });

init();

// Register Service Worker
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  });
}
</script>
</body>
</html>
